# ──────────────────────────────────────────────
# NGS Intelligence Platform — Environment Config
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# Server port (default: 3001)
PORT=3001

# PostgreSQL connection string
# Local:  postgresql://localhost:5432/ngs_platform
# Render: automatically set via render.yaml
DATABASE_URL=postgresql://localhost:5432/ngs_platform

# JWT signing secret (MUST change for production)
JWT_SECRET=change-me-in-production

# Node environment: development | production | test
NODE_ENV=development

# CORS allowed origin (frontend URL in development)
# Leave empty in production if serving frontend from Express
CORS_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────────
# Frontend (Vite — must be prefixed with VITE_)
# ──────────────────────────────────────────────

# API base URL (defaults to http://localhost:3001/api)
# Not needed in production when frontend is served by Express
# VITE_API_URL=http://localhost:3001/api
