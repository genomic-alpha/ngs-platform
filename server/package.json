  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.11.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2"
